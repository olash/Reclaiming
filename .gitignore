# ============================================================
# Reclaimng — .gitignore
# ============================================================

# --- Environment & Secrets (NEVER commit these) ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# --- Next.js build output ---
.next/
out/
build/

# --- Node modules ---
node_modules/

# --- Logs ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# --- OS files ---
.DS_Store
Thumbs.db

# --- IDE ---
.vscode/
.idea/

# --- TypeScript ---
*.tsbuildinfo

# --- Vercel ---
.vercel
